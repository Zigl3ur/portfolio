---
import ChevronDown from "../../icons/chevron-down.svg";
import { getLangFromUrl, translate } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const { landing: t } = translate(lang);
---

<section class="relative flex min-h-[calc(100vh-4.5rem)] flex-col">
  <div class="my-auto w-fit space-y-2">
    <h1 class="xs:text-5xl text-4xl font-bold md:text-6xl lg:text-7xl">
      Eden Douru
    </h1>
    <div class="text-md flex items-center gap-2 font-mono md:text-lg">
      <span class="text-lime-bright font-sans text-2xl font-bold">//</span>
      <span class="text-foreground/70 tracking-wide">{t.work}</span>
    </div>
  </div>
  <div class="mb-20 flex items-center justify-center">
    <a href="#about-me" class="transition duration-200 hover:-translate-y-1.5">
      <ChevronDown width={40} height={40} />
    </a>
  </div>
</section>
