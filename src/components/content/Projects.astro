---
import type { ProjectType } from "../../types";
import Card from "../ui/Card.astro";
import Title from "../ui/Title.astro";
import Arrow from "../../icons/arrow.svg";

import { getLangFromUrl, translate } from "../../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const { projects: t } = translate(lang);

const projects: ProjectType[] = [
  {
    name: "Jellyhub",
    description: t.jellyhubdesc,
    url: "https://github.com/Zigl3ur/jellyhub"
  },
  {
    name: "McJar",
    description: t.mcjardesc,
    url: "https://github.com/Zigl3ur/mcjar"
  },
  {
    name: "Portfolio",
    description: t.portfolio,
    url: "https://github.com/Zigl3ur/portfolio"
  }
];
---

<section>
  <Title id="projects" text={t.title} />
  <div class="space-y-6 overflow-x-hidden">
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      {
        projects.map((p: ProjectType) => {
          return (
            <a href={p.url} target="_blank">
              <Card class="group h-full space-y-4">
                <h3 class="flex items-center justify-between text-xl">
                  {p.name}
                  <Arrow
                    width={23}
                    height={23}
                    class="opacity-0 transition-opacity duration-300 group-hover:opacity-80"
                  />
                </h3>
                <p>{p.description}</p>
              </Card>
            </a>
          );
        })
      }
    </div>
  </div>
</section>
